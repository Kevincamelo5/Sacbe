[sub_resource type="GDScript" id="GDScript_db4q2"]
script/source = "extends CanvasLayer

func _ready():
	visible = false #cuadro oculto al principio
	# Es mejor configurar esto en el Inspector, pero por código sería:
	process_mode = Node.PROCESS_MODE_ALWAYS 
	
func mostrar():
	var tree = get_tree()
	if tree:
		visible = true
		tree.paused = true
	else:
		print(\"Error: El SceneTree no está disponible todavía.\")
	
#ocultar el cuadro y continuar
func _on_continuar_pressed():
	visible = false
	get_tree().paused = false
	pass # Replace with function body.


func _on_guardar_y_salir_pressed() -> void:
	get_tree().paused = false
	get_tree().change_scene_to_file(\"res://mapa/Menu/menu_principal.tscn\")
	pass # Replace with function body.

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"pausa\"):
			mostrar()


func _on_reinciar_pressed() -> void:
	print(\"reiniciando...\")
"

